<!-- app/views/dashboard/index.html.erb -->
<h1>Dashboard</h1>

<% if @current_user.role.name == 'admin' %>
  <div class="row">
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title"><%= @total_students %></h5>
          <p class="card-text">Total Students</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title"><%= @total_courses %></h5>
          <p class="card-text">Total Courses</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title"><%= @total_teachers %></h5>
          <p class="card-text">Total Teachers</p>
        </div>
      </div>
    </div>
  </div>

<% elsif @current_user.role.name == 'teacher' %>
  <h2>Your Dashboard</h2>
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title"><%= @courses&.count || 0 %></h5>
          <p class="card-text">Your Courses</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title"><%= @students_count %></h5>
          <p class="card-text">Unique Students</p>
        </div>
      </div>
    </div>
  </div>
  
  <h3>Your Courses</h3>
  <div class="row">
    <% if @courses %>
      <% @courses.each do |course| %>
        <div class="col-md-4 mb-3">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title"><%= course.title %></h5>
              <p class="card-text"><%= course.code %> - <%= course.credits %> credits</p>
              <a href="<%= edit_course_path(course) %>" class="btn btn-sm btn-warning">Edit</a>
              <a href="<%= course_path(course) %>" class="btn btn-sm btn-info">View</a>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p>No courses assigned to you.</p>
    <% end %>
  </div>
  
  <h3>Manage Student Enrollments</h3>
  <% if @enrolled_students && @enrolled_students.any? %>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Email</th>
          <th>Course</th>
          <th>Current Status</th>
          <th>Current Grade</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @enrolled_students.each do |student| %>
          <% student.enrollments.joins(:course).where(courses: { teacher: @current_user.teacher }).each do |enrollment| %>
            <tr>
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= student.user.email %></td>
              <td><%= enrollment.course.title %></td>
              <td><%= enrollment.status.capitalize %></td>
              <td><%= enrollment.grade || 'N/A' %></td>
              <td>
                <a href="<%= edit_enrollment_path(enrollment) %>" class="btn btn-sm btn-warning">Update</a>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No students enrolled in your courses.</p>
  <% end %>

<% elsif @current_user.role.name == 'student' %>
  <h2>Your Dashboard</h2>
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h5 class="card-title"><%= @enrolled_courses&.count || 0 %></h5>
          <p class="card-text">Your Courses</p>
        </div>
      </div>
    </div>
  </div>

  <h3>Your Courses</h3>
  <div class="row">
    <% if @enrolled_courses %>
      <% @enrolled_courses.each do |course| %>
        <div class="col-md-6 mb-3">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title"><%= course.title %></h5>
              <p class="card-text"><strong>Code:</strong> <%= course.code %></p>
              <p class="card-text"><strong>Description:</strong> <%= course.description %></p>
              <p class="card-text"><strong>Credits:</strong> <%= course.credits %></p>
              <p class="card-text">
                <strong>Instructor:</strong> 
                <%= course.teacher&.first_name %> <%= course.teacher&.last_name %> 
                (<%= course.teacher&.user&.email %>)
              </p>
              <small class="text-muted">Department: <%= course.teacher&.department %></small>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <p>You are not enrolled in any courses.</p>
    <% end %>
  </div>
<% end %>