<!-- app/views/courses/index.html.erb -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1 text-gradient-primary">Courses Catalog</h1>
    <p class="text-secondary mb-0">Manage and view all registered academic courses.</p>
  </div>
  <% if @current_user.role.name == 'admin' || @current_user.role.name == 'teacher' %>
    <%= link_to new_course_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg"></i> New Course
    <% end %>
  <% end %>
</div>

<div class="glass-card">
  <% if @courses && @courses.any? %>
    <div class="custom-table-container mb-3">
      <table class="custom-table">
        <thead>
          <tr>
            <th>Code</th>
            <th>Course Title</th>
            <th>Instructor</th>
            <th>Credits</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @courses.each do |course| %>
            <tr>
              <td>
                <span class="badge badge-teacher font-monospace"><%= course.code %></span>
              </td>
              <td>
                <span class="font-weight-bold text-white"><%= course.title %></span>
              </td>
              <td>
                <% if course.teacher.present? %>
                  <%= course.teacher.first_name %> <%= course.teacher.last_name %>
                <% else %>
                  <span class="text-muted small">No instructor</span>
                <% end %>
              </td>
              <td><span class="font-weight-bold" style="color: #6366f1;"><%= course.credits %></span></td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <%= link_to course_path(course), class: "btn btn-secondary btn-sm", title: "View" do %>
                    <i class="bi bi-eye"></i> View
                  <% end %>
                  <%= link_to edit_course_path(course), class: "btn btn-secondary btn-sm", style: "border-color: rgba(245, 158, 11, 0.3); color: #fbbf24;", title: "Edit" do %>
                    <i class="bi bi-pencil-square"></i> Edit
                  <% end if @current_user.role.name == 'admin' || (@current_user.role.name == 'teacher' && course.teacher == @current_user.teacher) %>
                  <%= button_to course_path(course), method: :delete, 
                       form: { data: { turbo_confirm: "Are you sure you want to delete this course?" } }, 
                       class: "btn btn-danger btn-sm", 
                       title: "Delete" do %>
                    <i class="bi bi-trash"></i> Delete
                  <% end if @current_user.role.name == 'admin' %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @courses %>
    </div>
  <% else %>
    <div class="text-center py-5 text-secondary">
      <i class="bi bi-journal-x d-block mb-2" style="font-size: 2.5rem;"></i>
      No courses found in the catalog.
    </div>
  <% end %>
</div>
