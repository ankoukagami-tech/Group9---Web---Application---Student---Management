"<!-- app/views/courses/show.html.erb -->\n<div class=\"d-flex align-items-center justify-content-between mb-4\">\n  <div>\n    <h1 class=\"mb-1 text-gradient-primary\">Course Details</h1>\n    <p class=\"text-secondary mb-0\">Detailed view of academic course curriculum and properties.</p>\n  </div>\n  <%= link_to courses_path, class: \"btn btn-secondary\" do %>\n    <i class=\"bi bi-arrow-left\"></i> Back to List\n  <% end %>\n</div>\n\n<div class=\"glass-card p-4 max-w-800 mx-auto\">\n  <div class=\"d-flex align-items-center gap-4 mb-4 pb-4 border-bottom border-color\">\n    <div class=\"stat-card-icon\" style=\"width: 72px; height: 72px; font-size: 2.25rem; border-radius: 20px;\">\n      <i class=\"bi bi-book-half\"></i>\n    </div>\n    <div>\n      <h3 class=\"font-weight-bold mb-1 text-gradient-primary\"><%= @course.title %></h3>\n      <div class=\"d-flex gap-2 align-items-center\">\n        <span class=\"custom-badge custom-badge-primary\"><%= @course.code %></span>\n        <span class=\"custom-badge custom-badge-success\"><%= @course.credits %> Credits</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"row g-4 mb-4\">\n    <div class=\"col-md-6\">\n      <span class=\"d-block small text-secondary\">Instructor</span>\n      <span class=\"font-weight-semibold text-primary fs-5\">\n        <%= @course.teacher ? \"#{@course.teacher.first_name} #{@course.teacher.last_name}\" : \"Not Assigned\" %>\n      </span>\n      <% if @course.teacher %>\n        <span class=\"d-block text-muted small\"><%= @course.teacher.department %> • <%= @course.teacher.user.email %></span>\n      <% end %>\n    </div>\n    <div class=\"col-md-6\">\n      <span class=\"d-block small text-secondary\">Schedule Period</span>\n      <span class=\"font-weight-semibold fs-5\"><%= @course.semester %> <%= @course.year %></span>\n    </div>\n    <div class=\"col-md-6\">\n      <span class=\"d-block small text-secondary\">Max Capacity</span>\n      <span class=\"font-weight-semibold fs-5\"><%= @course.max_capacity %> Seats</span>
