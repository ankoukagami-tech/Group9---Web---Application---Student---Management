<!-- app/views/enrollments/edit.html.erb -->
<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="mb-1 text-gradient-primary">Update Enrollment</h1>
    <p class="text-secondary mb-0">Modify grade and completion status for student academic course enrollment.</p>
  </div>
  <%= link_to dashboard_path, class: "btn btn-secondary" do %>
    <i class="bi bi-arrow-left"></i> Cancel
  <% end %>
</div>

<div class="glass-card max-w-800 mx-auto">
  <%= form_with model: @enrollment, local: true do |form| %>
    <% if @enrollment.errors.any? %>
      <div class="custom-alert custom-alert-danger mb-4">
        <i class="bi bi-x-circle-fill" style="font-size: 1.25rem;"></i>
        <div>
          <div class="font-weight-bold mb-1">Please fix the following errors:</div>
          <ul class="mb-0 small" style="padding-left: 1.25rem;">
            <% @enrollment.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label class="form-label">Student Name</label>
        <input type="text" class="form-control" value="<%= @enrollment.student.first_name %> <%= @enrollment.student.last_name %>" readonly disabled>
      </div>

      <div class="col-md-6">
        <label class="form-label">Course Title</label>
        <input type="text" class="form-control" value="<%= @enrollment.course.title %>" readonly disabled>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <%= form.label :status, "Enrollment Status", class: "form-label" %>
        <%= form.select :status, [['Enrolled', 'enrolled'], ['Completed', 'completed'], ['Dropped', 'dropped']], { prompt: "Select Status" }, { class: "form-select" } %>
      </div>

      <div class="col-md-6">
        <%= form.label :grade, "Grade / Mark", class: "form-label" %>
        <%= form.number_field :grade, step: 0.01, min: 0, max: 100, class: "form-control", placeholder: "e.g., 85.0" %>
        <div class="text-muted small mt-1" style="font-size: 0.75rem;">Enter grade between 0.00 and 100.00 (leave blank if pending)</div>
      </div>
    </div>

    <div class="detail-card-actions pt-4 border-top border-color">
      <%= form.submit "Update Enrollment", class: "btn btn-primary" %>
      <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>