<!-- app/views/enrollments/edit.html.erb -->
<h1>Update Enrollment</h1>

<%= form_with model: @enrollment, local: true do |form| %>
  <% if @enrollment.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @enrollment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <label class="form-label"><strong>Student:</strong></label>
    <input type="text" class="form-control" value="<%= @enrollment.student.first_name %> <%= @enrollment.student.last_name %>" readonly>
  </div>

  <div class="mb-3">
    <label class="form-label"><strong>Course:</strong></label>
    <input type="text" class="form-control" value="<%= @enrollment.course.title %>" readonly>
  </div>

  <div class="mb-3">
    <%= form.label :status, class: "form-label" %>
    <%= form.select :status, [['Enrolled', 'enrolled'], ['Completed', 'completed'], ['Dropped', 'dropped']], { prompt: "Select Status" }, { class: "form-control" } %>
  </div>

  <div class="mb-3">
    <%= form.label :grade, class: "form-label" %>
    <%= form.number_field :grade, step: 0.01, min: 0, max: 100, class: "form-control" %>
    <small class="form-text text-muted">Enter grade between 0 and 100 (leave blank if no grade)</small>
  </div>

  <div class="mb-3">
    <%= form.submit "Update Enrollment", class: "btn btn-primary" %>
    <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
  </div>
<% end %>