<!-- app/views/sessions/new.html.erb -->
<div class="glass-card auth-form-card mx-auto">
  <div class="text-center mb-4">
    <div class="stat-card-icon mx-auto mb-3" style="width: 56px; height: 56px; font-size: 1.75rem; background: var(--accent-primary-gradient); color: white; border: none; border-radius: 14px;">
      <i class="bi bi-mortarboard-fill"></i>
    </div>
    <h2 class="h3 mb-1 font-weight-bold text-gradient-primary">Welcome Back</h2>
    <p class="text-secondary small">Please sign in to access your portal</p>
  </div>
  
  <%= form_with url: login_path, local: true, method: :post do |form| %>
    <div class="mb-3">
      <%= form.label :email, class: "form-label" %>
      <div class="input-group">
        <span class="input-group-text border-end-0">
          <i class="bi bi-envelope"></i>
        </span>
        <%= form.email_field :email, class: "form-control border-start-0", placeholder: "name@example.com", required: true %>
      </div>
    </div>
    
    <div class="mb-4">
      <%= form.label :password, class: "form-label" %>
      <div class="input-group">
        <span class="input-group-text border-end-0">
          <i class="bi bi-lock"></i>
        </span>
        <%= form.password_field :password, class: "form-control border-start-0", placeholder: "••••••••", required: true %>
      </div>
    </div>
    
    <div class="mt-2">
      <%= form.submit "Sign In", class: "btn btn-primary w-100 py-2" %>
    </div>
  <% end %>
</div>