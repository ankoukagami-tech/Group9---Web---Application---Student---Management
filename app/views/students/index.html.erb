<!-- app/views/students/index.html.erb -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1 text-gradient-primary">Students Directory</h1>
    <p class="text-secondary mb-0">Manage registered students and view their academic status.</p>
  </div>
  <% if @current_user.role.name == 'admin' %>
    <%= link_to new_student_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg"></i> New Student
    <% end %>
  <% end %>
</div>

<div class="glass-card">
  <% if @students && @students.any? %>
    <div class="custom-table-container mb-3">
      <table class="custom-table">
        <thead>
          <tr>
            <th>Student Number</th>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @students.each do |student| %>
            <tr>
              <td>
                <span class="font-monospace text-secondary small"><%= student.student_number %></span>
              </td>
              <td>
                <span class="font-weight-bold text-white"><%= student.first_name %> <%= student.last_name %></span>
              </td>
              <td class="text-secondary"><%= student.user.email %></td>
              <td>
                <span class="badge <%= student.status == 'active' ? 'badge-student' : 'badge-danger' %>">
                  <%= student.status.capitalize %>
                </span>
              </td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <%= link_to student_path(student), class: "btn btn-secondary btn-sm", title: "View" do %>
                    <i class="bi bi-eye"></i> View
                  <% end %>
                  <%= link_to edit_student_path(student), class: "btn btn-secondary btn-sm", style: "border-color: rgba(245, 158, 11, 0.3); color: #fbbf24;", title: "Edit" do %>
                    <i class="bi bi-pencil-square"></i> Edit
                  <% end if @current_user.role.name == 'admin' || (@current_user.role.name == 'teacher' && student.enrollments.joins(:course).exists?(courses: { teacher: @current_user.teacher })) %>
                  <%= button_to student_path(student), method: :delete, 
                       form: { data: { turbo_confirm: "Are you sure you want to delete this student?" } }, 
                       class: "btn btn-danger btn-sm", 
                       title: "Delete" do %>
                    <i class="bi bi-trash"></i> Delete
                  <% end if @current_user.role.name == 'admin' %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @students %>
    </div>
  <% else %>
    <div class="text-center py-5 text-secondary">
      <i class="bi bi-people-fill d-block mb-2" style="font-size: 2.5rem;"></i>
      No students found in the directory.
    </div>
  <% end %>
</div>
