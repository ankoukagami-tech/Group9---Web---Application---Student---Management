<!-- app/views/teachers/index.html.erb -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1 text-gradient-primary">Teachers Directory</h1>
    <p class="text-secondary mb-0">Manage teaching staff, departments, and employee details.</p>
  </div>
  <% if @current_user.role.name == 'admin' %>
    <%= link_to new_teacher_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg"></i> New Teacher
    <% end %>
  <% end %>
</div>

<div class="glass-card">
  <% if @teachers && @teachers.any? %>
    <div class="custom-table-container mb-3">
      <table class="custom-table">
        <thead>
          <tr>
            <th>Employee Number</th>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @teachers.each do |teacher| %>
            <tr>
              <td>
                <span class="font-monospace text-secondary small"><%= teacher.employee_number %></span>
              </td>
              <td>
                <span class="font-weight-bold text-white"><%= teacher.first_name %> <%= teacher.last_name %></span>
              </td>
              <td class="text-secondary"><%= teacher.user.email %></td>
              <td>
                <span class="badge badge-teacher"><%= teacher.department.present? ? teacher.department : "N/A" %></span>
              </td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <%= link_to teacher_path(teacher), class: "btn btn-secondary btn-sm", title: "View" do %>
                    <i class="bi bi-eye"></i> View
                  <% end %>
                  <%= link_to edit_teacher_path(teacher), class: "btn btn-secondary btn-sm", style: "border-color: rgba(245, 158, 11, 0.3); color: #fbbf24;", title: "Edit" do %>
                    <i class="bi bi-pencil-square"></i> Edit
                  <% end if @current_user.role.name == 'admin' || @current_user.teacher == teacher %>
                  <%= button_to teacher_path(teacher), method: :delete, 
                       form: { data: { turbo_confirm: "Are you sure you want to delete this teacher?" } }, 
                       class: "btn btn-danger btn-sm", 
                       title: "Delete" do %>
                    <i class="bi bi-trash"></i> Delete
                  <% end if @current_user.role.name == 'admin' %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @teachers %>
    </div>
  <% else %>
    <div class="text-center py-5 text-secondary">
      <i class="bi bi-person-badge-fill d-block mb-2" style="font-size: 2.5rem;"></i>
      No teachers found in the directory.
    </div>
  <% end %>
</div>