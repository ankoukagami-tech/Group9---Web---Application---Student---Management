<!-- app/views/teachers/show.html.erb -->
<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="mb-1 text-gradient-primary">Teacher Profile</h1>
    <p class="text-secondary mb-0">Detailed view of registered instructor personal and career records.</p>
  </div>
  <%= link_to teachers_path, class: "btn btn-secondary" do %>
    <i class="bi bi-arrow-left"></i> Back to Directory
  <% end %>
</div>

<div class="glass-card">
  <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom border-color">
    <div class="stat-card-icon" style="background: rgba(168, 85, 247, 0.1); color: #a855f7; border-color: rgba(168, 85, 247, 0.2); width: 60px; height: 60px; font-size: 1.75rem;">
      <i class="bi bi-person-workspace"></i>
    </div>
    <div>
      <h3 class="text-white mb-1"><%= @teacher.first_name %> <%= @teacher.last_name %></h3>
      <span class="badge badge-teacher font-monospace"><%= @teacher.employee_number %></span>
    </div>
  </div>

  <h5 class="text-gradient-primary mb-3"><i class="bi bi-briefcase-fill me-2"></i>Employment Details</h5>
  <div class="detail-grid mb-4">
    <div class="detail-item">
      <div class="detail-label">Email Address</div>
      <div class="detail-value text-white"><%= @teacher.user.email %></div>
    </div>
    <div class="detail-item">
      <div class="detail-label">Department</div>
      <div class="detail-value"><span class="badge badge-teacher"><%= @teacher.department.present? ? @teacher.department : "N/A" %></span></div>
    </div>
    <div class="detail-item">
      <div class="detail-label">Hire Date</div>
      <div class="detail-value"><%= @teacher.hire_date&.strftime("%B %d, %Y") || "N/A" %></div>
    </div>
  </div>

  <div class="detail-card-actions pt-4 border-top border-color">
    <% if @current_user.role.name == 'admin' || @current_user.teacher == @teacher %>
      <%= link_to edit_teacher_path(@teacher), class: "btn btn-primary" do %>
        <i class="bi bi-pencil-square"></i> Edit Profile
      <% end %>
    <% end %>
    
    <% if @current_user.role.name == 'admin' %>
      <%= button_to teacher_path(@teacher), method: :delete, 
           form: { data: { turbo_confirm: "Are you sure you want to delete this teacher?" } }, 
           class: "btn btn-danger" do %>
        <i class="bi bi-trash"></i> Delete Teacher
      <% end %>
    <% end %>
  </div>
</div>