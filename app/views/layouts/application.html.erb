<!-- app/views/layouts/application.html.erb -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <title>EduManage | Student Management System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Custom Application CSS (Design System) -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <% if @current_user %>
      <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="app-sidebar">
          <div class="sidebar-logo">
            <span class="stat-card-icon" style="width: 38px; height: 38px; font-size: 1.25rem; background: var(--accent-primary-gradient); color: white; border: none; border-radius: 10px;">
              <i class="bi bi-mortarboard-fill"></i>
            </span>
            <span class="sidebar-logo-text">EduManage</span>
          </div>

          <div class="sidebar-menu">
            <%= link_to dashboard_path, class: "sidebar-link #{'active' if current_page?(dashboard_path)}" do %>
              <i class="bi bi-grid-1x2-fill"></i> Dashboard
            <% end %>

            <% if @current_user.role.name == 'admin' %>
              <%= link_to students_path, class: "sidebar-link #{'active' if current_page?(students_path) || params[:controller] == 'students'}" do %>
                <i class="bi bi-people-fill"></i> Students
              <% end %>
              <%= link_to teachers_path, class: "sidebar-link #{'active' if current_page?(teachers_path) || params[:controller] == 'teachers'}" do %>
                <i class="bi bi-person-badge-fill"></i> Teachers
              <% end %>
              <%= link_to courses_path, class: "sidebar-link #{'active' if current_page?(courses_path) || params[:controller] == 'courses'}" do %>
                <i class="bi bi-journal-bookmark-fill"></i> Courses
              <% end %>
              <%= link_to enrollments_path, class: "sidebar-link #{'active' if current_page?(enrollments_path) || params[:controller] == 'enrollments'}" do %>
                <i class="bi bi-clipboard-check-fill"></i> Enrollments
              <% end %>
            <% elsif @current_user.role.name == 'teacher' %>
              <%= link_to courses_path, class: "sidebar-link #{'active' if current_page?(courses_path) || params[:controller] == 'courses'}" do %>
                <i class="bi bi-journal-bookmark-fill"></i> My Courses
              <% end %>
              <%= link_to students_path, class: "sidebar-link #{'active' if current_page?(students_path) || params[:controller] == 'students'}" do %>
                <i class="bi bi-people-fill"></i> My Students
              <% end %>
            <% elsif @current_user.role.name == 'student' %>
              <%= link_to my_courses_enrollments_path, class: "sidebar-link #{'active' if current_page?(my_courses_enrollments_path)}" do %>
                <i class="bi bi-journal-check"></i> My Enrolled Courses
              <% end %>
            <% end %>
          </div>

          <div class="sidebar-footer">
            <div class="d-flex align-items-center justify-content-between">
              <div class="user-info text-truncate me-2">
                <div class="small font-weight-bold text-white text-truncate"><%= @current_user.email %></div>
                <div class="text-muted text-uppercase" style="font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em;"><%= @current_user.role.name %></div>
              </div>
              <%= button_to logout_path, method: :delete, class: "btn btn-link p-2 text-danger sidebar-link-logout", form_class: "d-inline", title: "Logout" do %>
                <i class="bi bi-box-arrow-right" style="font-size: 1.25rem;"></i>
              <% end %>
            </div>
          </div>
        </aside>

        <!-- Main Content Panel -->
        <main class="main-content">
          <% if notice %>
            <div class="custom-alert custom-alert-success fade show">
              <i class="bi bi-check-circle-fill"></i>
              <div><%= notice %></div>
            </div>
          <% end %>
          
          <% if alert %>
            <div class="custom-alert custom-alert-danger fade show">
              <i class="bi bi-exclamation-triangle-fill"></i>
              <div><%= alert %></div>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    <% else %>
      <!-- Non-logged in Users (Auth Pages) -->
      <div class="auth-wrapper">
        <div class="w-100">
          <% if notice %>
            <div class="custom-alert custom-alert-success mx-auto mb-3" style="max-width: 440px;">
              <i class="bi bi-check-circle-fill"></i>
              <div><%= notice %></div>
            </div>
          <% end %>
          
          <% if alert %>
            <div class="custom-alert custom-alert-danger mx-auto mb-3" style="max-width: 440px;">
              <i class="bi bi-exclamation-triangle-fill"></i>
              <div><%= alert %></div>
            </div>
          <% end %>
          
          <%= yield %>
        </div>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>