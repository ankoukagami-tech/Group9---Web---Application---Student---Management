# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.erb

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage files, which are used for user-generated content in development.
/storage/*
!/storage/.keep

# Ignore uploaded files in development.
/public/uploads

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore application configuration
/config/application.yml

# Ignore Ruby Version Manager files.
.rvmrc
.rbenv-version

# Ignore SQLite databases (if using SQLite in development).
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-[0-9]*

# Ignore Byebug history.
.byebug_history

# Ignore SimpleCov coverage reports.
/coverage

# Ignore vendor/bundle if you're vendoring gems.
/vendor/bundle

# Ignore node_modules if using JavaScript.
/node_modules

# Ignore Yarn files.
yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore Docker-related files if not committing them (optional; adjust as needed).
# /.dockerignore  # Uncomment if you don't want to commit it

# Ignore macOS .DS_Store files.
.DS_Store

# Ignore Vim swap files.
*.swp

# Ignore JetBrains IDE files.
.idea/

# Ignore VS Code settings.
.vscode/

# Ignore precompiled assets.
/public/assets
/public/packs
/public/packs-test